model Member {
  id                Int      @id @default(autoincrement())
  name              String   @db.VarChar(255)
  phone             String   @db.VarChar(50)
  email             String?  @db.VarChar(255)
  address           String?  @db.VarChar(500)
  join_date         DateTime @db.Timestamptz
  emergency_contact String   @db.VarChar(255)
  photo_url         String?  @db.VarChar(1000)
  height            Float?
  weight            Float?
  status            String   @default("pending") // "active", "expired", "pending"
  registration_fee  Decimal  @default(0.00) @db.Decimal(10, 2)
  
  gym_id            Int
  plan_id           Int?
  
  gym               Gym      @relation(fields: [gym_id], references: [id], onDelete: Restrict)
  plan              Plan?    @relation(fields: [plan_id], references: [id], onDelete: Restrict)
  
  payments          Payment[]

  created_at        DateTime @default(now()) @db.Timestamptz
  updated_at        DateTime @default(now()) @updatedAt @db.Timestamptz

  @@map("members")
}
