model Member {
  id                Int      @id @default(autoincrement())
  name              String   @db.VarChar(255)
  phone             String   @db.VarChar(50)
  email             String?  @db.VarChar(255)
  address           String?  @db.VarChar(500)
  join_date         DateTime @db.Timestamptz
  emergency_contact String   @db.VarChar(255)
  photo_url         String?  @db.VarChar(1000)
  height            Float?
  weight            Float?
  status            String   @default("active") // "active", "expired", "pending"
  
  gym_id            Int
  plan_id           Int
  
  gym               Gym      @relation(fields: [gym_id], references: [id], onDelete: Cascade)
  plan              Plan     @relation(fields: [plan_id], references: [id], onDelete: Cascade)
  
  payments          Payment[]

  created_at        DateTime @default(now()) @db.Timestamptz
  updated_at        DateTime @default(now()) @updatedAt @db.Timestamptz

  @@map("members")
}
