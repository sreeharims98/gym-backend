model Todo {
  id           Int      @id @default(autoincrement())
  title        String   @db.VarChar(255)
  content      String?
  is_completed Boolean  @default(false)
  created_at   DateTime @default(now()) @db.Timestamptz
  updated_at   DateTime @default(now()) @updatedAt @db.Timestamptz

  @@map("todos")
}
