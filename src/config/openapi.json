{
  "openapi": "3.0.0",
  "info": {
    "title": "Minimal Multi-Gym Management API",
    "version": "1.0.0",
    "description": "Interactive API specification for managing multiple gym branches, dynamic membership plans, member registration, fee collections, and WhatsApp reminder generation."
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Local Development Server"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Enter the JWT Bearer Token received from the Login API endpoint to authenticate."
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "string", "example": "error" },
          "statusCode": { "type": "integer", "example": 400 },
          "message": { "type": "string", "example": "Validation failed" }
        }
      }
    }
  },
  "paths": {
    "/api/auth/register": {
      "post": {
        "tags": ["Authentication"],
        "summary": "Register a new Operator",
        "description": "Creates a new system operator (Owner or Gym Staff). Owners can manage all branches, while Staff are restricted to their specific branch.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password", "role"],
                "properties": {
                  "email": { "type": "string", "format": "email", "example": "owner@gym.com" },
                  "password": { "type": "string", "minLength": 6, "example": "securepass123" },
                  "role": { "type": "string", "enum": ["owner", "staff"], "example": "owner" },
                  "gym_id": { "type": "integer", "nullable": true, "example": 1 }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Operator registered successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": { "type": "integer", "example": 1 },
                    "email": { "type": "string", "example": "owner@gym.com" },
                    "role": { "type": "string", "example": "owner" },
                    "gym_id": { "type": "integer", "nullable": true, "example": null },
                    "created_at": { "type": "string", "format": "date-time" }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Email already exists / Validation failed",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } }
            }
          }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "tags": ["Authentication"],
        "summary": "Operator Log In",
        "description": "Verifies password and issues a custom JWT signature token loaded with operator metadata.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                  "email": { "type": "string", "format": "email", "example": "owner@gym.com" },
                  "password": { "type": "string", "example": "securepass123" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Log in successful, returns JWT token",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "user": {
                      "type": "object",
                      "properties": {
                        "id": { "type": "integer", "example": 1 },
                        "email": { "type": "string", "example": "owner@gym.com" },
                        "role": { "type": "string", "example": "owner" },
                        "gym_id": { "type": "integer", "nullable": true, "example": null }
                      }
                    },
                    "token": { "type": "string", "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6MSwiZW1haWwiOi..." }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Invalid credentials",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } }
            }
          }
        }
      }
    },
    "/api/gyms": {
      "get": {
        "tags": ["Gym Branches"],
        "summary": "List all branches",
        "description": "Returns all gym locations registered in the system. (Authenticated)",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "List of branches",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": { "type": "integer", "example": 1 },
                      "name": { "type": "string", "example": "Chennai Branch" },
                      "location": { "type": "string", "example": "Adyar, Chennai" },
                      "contact_no": { "type": "string", "example": "+91 98765 43210" }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Gym Branches"],
        "summary": "Create a branch",
        "description": "Registers a new gym location branch. Restricted to Owners only. (Authenticated)",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "location", "contact_no"],
                "properties": {
                  "name": { "type": "string", "example": "Bangalore Branch" },
                  "location": { "type": "string", "example": "Indiranagar, Bangalore" },
                  "contact_no": { "type": "string", "example": "+91 87654 32109" }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Branch created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": { "type": "integer", "example": 2 },
                    "name": { "type": "string", "example": "Bangalore Branch" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/gyms/{id}": {
      "get": {
        "tags": ["Gym Branches"],
        "summary": "Get branch by ID",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Branch details" },
          "404": { "description": "Branch not found" }
        }
      },
      "put": {
        "tags": ["Gym Branches"],
        "summary": "Update branch",
        "description": "Restricted to Owners only. (Authenticated)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string", "example": "Bangalore Main Branch" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Branch updated successfully" }
        }
      },
      "delete": {
        "tags": ["Gym Branches"],
        "summary": "Delete branch",
        "description": "Restricted to Owners only. (Authenticated)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "204": { "description": "Branch deleted successfully" }
        }
      }
    },
    "/api/plans": {
      "get": {
        "tags": ["Membership Plans"],
        "summary": "List all plans",
        "description": "Fetches all preconfigured dynamic packages (Monthly, Yearly, etc.). (Authenticated)",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "List of plans"
          }
        }
      },
      "post": {
        "tags": ["Membership Plans"],
        "summary": "Create a plan",
        "description": "Adds a dynamic plan. Restricted to Owners only. (Authenticated)",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "duration_months", "price"],
                "properties": {
                  "name": { "type": "string", "example": "3 Months Package" },
                  "duration_months": { "type": "integer", "example": 3 },
                  "price": { "type": "number", "example": 4500 }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Plan created successfully" }
        }
      }
    },
    "/api/plans/{id}": {
      "get": {
        "tags": ["Membership Plans"],
        "summary": "Get plan details",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Plan details" }
        }
      },
      "put": {
        "tags": ["Membership Plans"],
        "summary": "Update dynamic plan",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "price": { "type": "number", "example": 4200 }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Plan updated" }
        }
      },
      "delete": {
        "tags": ["Membership Plans"],
        "summary": "Delete plan",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "204": { "description": "Plan deleted" }
        }
      }
    },
    "/api/members": {
      "get": {
        "tags": ["Members Management"],
        "summary": "Search & Filter gym members",
        "description": "Returns members matched against filters like phone, gym_id, status, or search query. (Authenticated)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "search", "in": "query", "description": "Search by name or phone", "schema": { "type": "string" } },
          { "name": "gym_id", "in": "query", "description": "Filter by branch ID", "schema": { "type": "integer" } },
          { "name": "status", "in": "query", "description": "Filter by active/expired/pending", "schema": { "type": "string", "enum": ["active", "expired", "pending"] } }
        ],
        "responses": {
          "200": { "description": "List of matched members" }
        }
      },
      "post": {
        "tags": ["Members Management"],
        "summary": "Register a new Member",
        "description": "Registers a member, computes membership expiry, and atomicly posts their first unpaid invoice. (Authenticated)",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "phone", "join_date", "emergency_contact", "gym_id", "plan_id"],
                "properties": {
                  "name": { "type": "string", "example": "John Doe" },
                  "phone": { "type": "string", "example": "9876543210" },
                  "email": { "type": "string", "format": "email", "example": "john@gmail.com" },
                  "address": { "type": "string", "example": "123 Park Street, Chennai" },
                  "join_date": { "type": "string", "format": "date", "example": "2026-05-25" },
                  "emergency_contact": { "type": "string", "example": "Jane Doe (+91 99999 88888)" },
                  "height": { "type": "number", "description": "Height in cm (optional)", "example": 178.5 },
                  "weight": { "type": "number", "description": "Weight in kg (optional)", "example": 72.3 },
                  "gym_id": { "type": "integer", "example": 1 },
                  "plan_id": { "type": "integer", "example": 1 }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Member registered and invoice created successfully"
          }
        }
      }
    },
    "/api/members/{id}": {
      "get": {
        "tags": ["Members Management"],
        "summary": "Get member profile and payment history",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Member complete profile" }
        }
      },
      "put": {
        "tags": ["Members Management"],
        "summary": "Update member profile",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "weight": { "type": "number", "example": 70.8 }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Member details updated" }
        }
      },
      "delete": {
        "tags": ["Members Management"],
        "summary": "Delete member record",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "204": { "description": "Member record deleted" }
        }
      }
    },
    "/api/payments/dashboard/overdue": {
      "get": {
        "tags": ["Payments & Dashboards"],
        "summary": "Overdue & Dues Dashboard",
        "description": "Segments unpaid/partial invoices into 'due_today', 'due_this_week', and 'overdue' categories. Features delay counts and click-to-send prefilled WhatsApp link payloads. (Authenticated)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "gym_id", "in": "query", "description": "Filter dashboard by Branch ID (optional for owners, automatic for staff)", "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "Segmented dashboard data with WhatsApp links",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "due_today": { "type": "array", "items": { "type": "object" } },
                    "due_this_week": { "type": "array", "items": { "type": "object" } },
                    "overdue": { "type": "array", "items": { "type": "object" } }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/payments/dashboard/stats": {
      "get": {
        "tags": ["Payments & Dashboards"],
        "summary": "Reports and Revenue Stats",
        "description": "Calculates global metrics including collected totals, pending dues, member counts, overdue count, and branch-wise revenue statistics. (Authenticated)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "gym_id", "in": "query", "description": "Filter dashboard statistics by Branch ID", "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "Statistics aggregation"
          }
        }
      }
    },
    "/api/payments/reminder/{id}/whatsapp": {
      "get": {
        "tags": ["Payments & Dashboards"],
        "summary": "Individual WhatsApp prefilled reminder link",
        "description": "Retrieves copy-paste text content and formatted click-to-send redirection wa.me links for a specific invoice ID. (Authenticated)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "Redirection reminder details",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "text": { "type": "string" },
                    "link": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/payments/pay/{id}": {
      "post": {
        "tags": ["Payments & Dashboards"],
        "summary": "Record a fee Payment / Collection",
        "description": "Processes a fee collection for an invoice, updates balances, and automatically activates the member on complete settlements. (Authenticated)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["amount_paid"],
                "properties": {
                  "amount_paid": { "type": "number", "example": 1500 }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Payment logged successfully" }
        }
      }
    },
    "/api/payments/renew/{id}": {
      "post": {
        "tags": ["Payments & Dashboards"],
        "summary": "Renew membership",
        "description": "Extends a member's package, shifts their profile status to Active, and atomicly records a new unpaid Payment invoice for tracking. (Authenticated)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer", "description": "Member ID" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["plan_id"],
                "properties": {
                  "plan_id": { "type": "integer", "example": 2 },
                  "payment_date": { "type": "string", "format": "date", "example": "2026-05-25" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Membership package renewed" }
        }
      }
    }
  }
}
